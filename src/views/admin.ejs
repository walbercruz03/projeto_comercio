<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Administrativo</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/administrador.css">
    
    <style>
        body {
            background-color: <%= layout.cor_fundo_dashboard %> !important;
            display: flex;
            margin: 0;
            font-family: Arial, sans-serif;
            height: 100vh;
        }
        /* Layout Lateral Corrigido e Proporcional */
        .sidebar {
            width: 260px;
            background-color: #ffffff;
            border-right: 1px solid #e0e0e0;
            height: 100vh;
            padding: 20px 10px;
            box-sizing: border-box;
            position: fixed;
            left: 0;
            top: 0;
            z-index: 100;
        }
        .main-content {
            margin-left: 260px;
            flex: 1;
            padding: 40px;
            overflow-y: auto;
            box-sizing: border-box;
        }
        .sidebar-title {
            font-weight: bold;
            color: #1a2a3a;
            padding: 12px;
            background-color: #f4f6f8;
            border-radius: 8px;
            margin-bottom: 20px;
            text-align: center;
        }
        .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            width: 100%;
            background: none;
            border: none;
            padding: 12px 15px;
            color: #666;
            font-size: 16px;
            cursor: pointer;
            border-radius: 6px;
            text-align: left;
            transition: all 0.2s;
            margin-bottom: 5px;
        }
        .menu-item:hover {
            background-color: #f5f5f5;
            color: #333;
        }
        .menu-item.active {
            background-color: #f0f4f8;
            color: <%= layout.cor_primaria %> !important;
            font-weight: bold;
        }
        .tab-conteudo {
            display: none;
        }
        .tab-conteudo.active {
            display: block;
        }
        .btn-enviar, .btn-adicionar {
            background-color: <%= layout.cor_primaria %> !important;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }
        /* Tabela de Itens da Venda */
        .tabela-venda {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
            background: white;
        }
        .tabela-venda th, .tabela-venda td {
            border: 1px solid #ddd;
            padding: 10px;
            text-align: left;
        }
        .tabela-venda th {
            background-color: #f4f6f8;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-title">
            <i class="fa-solid fa-user-shield"></i> Painel Administrador
        </div>
        
        <div style="text-align: center; margin-bottom: 20px;">
            <img src="<%= layout.logo_url %>" alt="Logo" style="max-height: 50px; object-fit: contain;">
        </div>

        <button class="menu-item active" onclick="alternarAba('aba-dashboard', this)">
            <i class="fa-solid fa-chart-line"></i> Dashboard / Início
        </button>
        <button class="menu-item" id="btnAbaProdutos" onclick="alternarAba('aba-produtos', this)">
            <i class="fa-solid fa-box"></i> Cadastrar Produto
        </button>
        <button class="menu-item" onclick="alternarAba('aba-venda-presencial', this)">
            <i class="fa-solid fa-cash-register"></i> Venda Presencial
        </button>
        <button class="menu-item" onclick="alternarAba('aba-customizacao', this)">
            <i class="fa-solid fa-palette"></i> Customizar Loja
        </button>
        
        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <button class="menu-item" onclick="window.location.href='/produtos'" style="color: #666;">
            <i class="fa-solid fa-store"></i> Ver Vitrine Pública
        </button>
        <button class="menu-item" onclick="window.location.href='/logout'" style="color: #cc0000;">
            <i class="fa-solid fa-right-from-bracket"></i> Sair / Logoff
        </button>
    </div>

    <div class="main-content">

        <div id="aba-dashboard" class="tab-conteudo active">
            <h2 class="titulo-secao">Bem-vindo ao Painel de Controle</h2>
            <p>Selecione uma opção no menu lateral para iniciar as operações.</p>
        </div>

        <div id="aba-produtos" class="tab-conteudo">
            <h2 class="titulo-secao" id="tituloFormProduto">Cadastrar Novo Produto</h2>
            <form id="formProduto">
                <div class="form-group">
                    <label for="nome">Nome do Produto</label>
                    <input type="text" id="nome" required>
                </div>
                <div class="form-group">
                    <label for="preco">Preço (R$)</label>
                    <input type="number" id="preco" step="0.01" required>
                </div>
                <div class="form-group">
                    <label for="estoque">Quantidade em Estoque</label>
                    <input type="number" id="estoque" required>
                </div>
                <div class="form-group">
                    <label for="descricao">Descrição</label>
                    <textarea id="descricao" required></textarea>
                </div>
                <div class="form-group">
                    <label for="imagem">Imagem do Produto</label>
                    <input type="file" id="imagem" accept="image/*" required>
                </div>
                <button type="submit" class="btn-enviar" id="btnSalvarProduto">Cadastrar Produto</button>
            </form>
        </div>

        <div id="aba-venda-presencial" class="tab-conteudo">
            <h2 class="titulo-secao">Emissão de Cupom de Venda Presencial</h2>
            
            <div class="form-group" style="margin-bottom: 15px;">
                <label for="vendaCliente">Nome do Cliente (Opcional)</label>
                <input type="text" id="vendaCliente" style="width: 100%; padding: 8px;" placeholder="Consumidor Final" value="Consumidor Final">
            </div>

            <div style="background: #f8f9fa; padding: 15px; border-radius: 6px; margin-bottom: 20px; border: 1px solid #e2e8f0;">
                <h4 style="margin-top: 0; margin-bottom: 10px;">Adicionar Produto à Venda</h4>
                <div style="display: flex; gap: 15px; align-items: flex-end;">
                    <div style="flex: 2;">
                        <label for="vendaProduto" style="display:block; margin-bottom:5px;">Selecione o Produto</label>
                        <select id="vendaProduto" style="width: 100%; padding: 10px; border-radius: 5px; border: 1px solid #ccc; background: white;">
                            <option value="">Carregando produtos...</option>
                        </select>
                    </div>
                    <div style="flex: 1;">
                        <label for="vendaQuantidade" style="display:block; margin-bottom:5px;">Qtd</label>
                        <input type="number" id="vendaQuantidade" min="1" value="1" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 5px;">
                    </div>
                    <div>
                        <button type="button" class="btn-adicionar" onclick="adicionarItemAoCarrinho()">
                            <i class="fa-solid fa-plus"></i> Adicionar
                        </button>
                    </div>
                </div>
            </div>

            <h3>Itens da Venda</h3>
            <table class="tabela-venda" id="tabelaItensVenda">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th>Qtd</th>
                        <th>Preço Unit.</th>
                        <th>Total</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="5" style="text-align: center; color: #999;">Nenhum produto adicionado ainda.</td>
                    </tr>
                </tbody>
            </table>

            <div style="text-align: right; margin-top: 20px;">
                <h3 id="txtTotalVenda">Total Geral: R$ 0,00</h3>
                <button type="button" class="btn-enviar" onclick="finalizarVendaPresencial()" style="padding: 12px 30px; font-size: 16px;">
                    <i class="fa-solid fa-print"></i> Emitir Cupom / Fechar Venda
                </button>
            </div>
        </div>

        <div id="aba-customizacao" class="tab-conteudo">
            <h2 class="titulo-secao">Identidade Visual da Loja</h2>
            <form id="formCustomizarLoja" enctype="multipart/form-data">
                <div class="form-group">
                    <label for="selectPagina">Escolha a Página para alterar o Fundo:</label>
                    <select id="selectPagina" name="pagina">
                        <option value="produtos">Vitrine de Produtos</option>
                        <option value="carrinho">Carrinho de Compras</option>
                        <option value="login">Tela de Login</option>
                        <option value="cadastro">Tela de Cadastro</option>
                        <option value="dashboard">Dashboard do Admin</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="corFundo">Cor de Fundo:</label>
                    <input type="color" id="corFundo" name="cor_fundo" value="#ffffff">
                </div>
                <div class="form-group">
                    <label for="corPrimaria">Cor Primária Global:</label>
                    <input type="color" id="corPrimaria" name="cor_primaria" value="<%= layout.cor_primaria %>">
                </div>
                <div class="form-group">
                    <label for="logoEmpresa">Nova Imagem da Logo:</label>
                    <input type="file" id="logoEmpresa" name="logo" accept="image/*">
                </div>
                <button type="submit" class="btn-enviar">Salvar Configurações</button>
            </form>
        </div>

    </div>

    <script src="/js/administrador.js"></script>
</body>
</html>