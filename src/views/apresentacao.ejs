<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apresentação - Comércio</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/apresentacao_moderna.css">
</head>
<body>

    <nav class="navbar">
        <div class="navbar-left">
            <button class="menu-toggle" id="btnMenu" title="Abrir Menu">
                <i class="fa-solid fa-bars"></i>
            </button>
            <div class="navbar-brand">
                <i class="fa-solid fa-store"></i>
                <h2>Meu Comércio</h2>
            </div>
        </div>
        <div class="navbar-actions">
            <div class="theme-switcher">
                <i class="fa-solid fa-sun"></i>
                <label class="switch">
                    <input type="checkbox" id="themeToggle">
                    <span class="slider round"></span>
                </label>
                <i class="fa-solid fa-moon"></i>
            </div>
        </div>
    </nav>

    <div class="sidebar" id="sidebarMenu">
        <div id="perfilUsuario" class="badge-perfil">Carregando...</div>
        <hr>
        <div id="itensMenu"></div>
        <hr>
        <a href="#" id="btnSair"><i class="fa-solid fa-right-from-bracket"></i> Sair / Logoff</a>
    </div>

    <div class="overlay" id="menuOverlay"></div>

    <header class="hero">
        <div class="hero-content">
            <h1 id="boasVindasTitulo">As melhores ofertas, a um clique de distância.</h1>
            <p>Qualidade, variedade e segurança em sua compra.</p>
        </div>
    </header>

    <main class="main-content">
        <div class="store-header">
            <h2 class="section-title" id="tituloVitrine">Nossos Produtos</h2>
            <div class="category-filters" id="categoryFilters">
                </div>
        </div>
        <div class="grid-produtos" id="listaProdutos"></div>
    </main>

    <script src="/js/apresentacao.js"></script>
</body>
</html>