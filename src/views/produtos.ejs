<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catálogo de Produtos - Wc Variedades</title>
    <link class="component-style" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link class="component-style" rel="stylesheet" href="/css/apresentacao_moderna.css">
</head>
<body>

    <nav class="navbar">
        <div class="navbar-left">
            <button class="menu-toggle" id="btnMenu" title="Abrir Menu">
                <i class="fa-solid fa-bars"></i>
            </button>
            <div class="navbar-brand">
                <i class="fa-solid fa-store"></i>
                <h2>Wc Variedades</h2>
            </div>
        </div>
        <div class="navbar-actions">
            <div class="theme-switcher">
                <i class="fa-solid fa-sun"></i>
                <label class="switch">
                    <input type="checkbox" id="themeToggle">
                    <span class="slider round"></span>
                </label>
                <i class="fa-solid fa-moon"></i>
            </div>
        </div>
    </nav>

    <div class="sidebar" id="sidebarMenu">
        <div id="perfilUsuario" class="badge-perfil">
            <i class="fa-solid <%= isAdmin ? 'fa-user-shield' : 'fa-user' %>"></i> 
            <%= isAdmin ? 'Painel Administrador' : 'Painel Cliente' %>
        </div>
        <hr>
        <div id="itensMenu" class="menu-links-container">
            <a href="/produtos" class="menu-item active"><i class="fa-solid fa-house"></i> Início</a>
            
            <% if (isAdmin) { %>
                <a href="/dashboard" class="menu-item"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
                <a href="/produtos" class="menu-item"><i class="fa-solid fa-boxes-stacked"></i> Gerenciar Catálogo</a>
                <a href="/admin" class="menu-item"><i class="fa-solid fa-plus"></i> Cadastrar Produto</a>
                <a href="/gerenciar_admins" class="menu-item"><i class="fa-solid fa-users-gear"></i> Gerenciar Admins</a>
            <% } else { %>
                <a href="/carrinho" class="menu-item"><i class="fa-solid fa-cart-shopping"></i> Meu Carrinho</a>
                <a href="/meus_pedidos" class="menu-item"><i class="fa-solid fa-clipboard-list"></i> Meus Pedidos</a>
            <% } %>
        </div>
        <hr>
        <a href="#" id="btnSair"><i class="fa-solid fa-right-from-bracket"></i> Sair / Logoff</a>
    </div>

    <div class="overlay" id="menuOverlay"></div>

    <header class="hero">
        <div class="hero-content">
            <h1 id="boasVindasTitulo">Catálogo Oficial de Produtos</h1>
            <p>Qualidade, variedade e segurança em sua compra.</p>
        </div>
    </header>

    <main class="main-content">
        <div class="store-header">
            <h2 class="section-title" id="tituloVitrine">Nossos Produtos</h2>
            <div class="category-filters" id="categoryFilters"></div>
        </div>

        <div class="grid-produtos" id="listaProdutos">
            <% if (produtos && produtos.length > 0) { %>
                <% produtos.forEach(prod => { %>
                    
                   <div class="card-produto" data-id="<%= prod.id_produto %>">
    
    <% 
        // Define a imagem padrão (placeholder) caso o produto venha sem imagem do banco
        let srcImagem = "/images/produto-placeholder.png"; 
        
        if (prod.imagem) {
            // Se o caminho já for uma URL completa ou já começar com barra, mantém
            if (prod.imagem.startsWith('http') || prod.imagem.startsWith('/')) {
                srcImagem = prod.imagem;
            } else {
                // 🆕 CORREÇÃO: Aponta para a pasta real onde o upload foi salvo
                srcImagem = "/uploads/" + prod.imagem; 
            }
        }
    %>
    <img src="<%= srcImagem %>" alt="<%= prod.nome %>">
    
    <div class="produto-info">
                            <h3><%= prod.nome %></h3>
                            <p><%= prod.descricao %></p>
                            
                            <div class="preco">R$ <%= parseFloat(prod.preco).toFixed(2).replace('.', ',') %></div>
                            <small style="display: block; margin-bottom: 1rem; color: var(--text-color-light);">Estoque: <%= prod.estoque %></small>
                            
                            <% if (!isAdmin) { %>
                                <button class="btn-add" 
                                        onclick="comprarProduto(<%= prod.id_produto %>, '<%= prod.nome %>', <%= prod.preco %>)"
                                        <%= prod.estoque <= 0 ? 'disabled' : '' %>>
                                    <i class="fa-solid fa-cart-plus"></i> Adicionar
                                </button>
                            <% } %>

                            <% if (isAdmin) { %>
                                <div class="admin-card-actions" style="margin-top: 0.5rem;">
                                    <button class="btn-edit" title="Editar Produto" 
                                            onclick="window.location.href='/admin?edit=<%= prod.id_produto %>'">
                                        <i class="fa-solid fa-pen-to-square"></i> Editar
                                    </button>
                                    <button class="btn-delete" title="Excluir Produto" 
                                            onclick="excluirProduto(<%= prod.id_produto %>, '<%= prod.nome %>')">
                                        <i class="fa-solid fa-trash"></i> Excluir
                                    </button>
                                </div>
                            <% } %>
                        </div>
                    </div>

                <% }) %>
            <% } else { %>
                <div class="alerta-vazio" style="grid-column: 1/-1; text-align: center; padding: 40px; color: var(--text-color-light);">
                    <i class="fa-solid fa-boxes-empty" style="font-size: 48px; margin-bottom: 15px;"></i>
                    <p>Nenhum produto cadastrado no catálogo.</p>
                </div>
            <% } %>
        </div>
    </main>

    <script src="/js/apresentacao.js"></script>
</body>
</html>