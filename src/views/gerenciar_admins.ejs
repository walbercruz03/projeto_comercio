<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestão de Administradores - Wc Variedades</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/apresentacao_moderna.css">
    <!-- ⚡ REATORAÇÃO: Link para o arquivo CSS externo -->
    <link rel="stylesheet" href="/css/gerenciar_admins.css">
</head>
<body>

    <% if (!locals.usuarioLogado || locals.usuarioLogado.tipo_usuario !== 'admin_principal') { %>
        <div class="container" style="max-width: 600px; margin: 0 auto;">
            <div class="erro-container">
                <h2><i class="fa-solid fa-triangle-exclamation"></i> Acesso Negado</h2>
                <p style="margin: 15px 0;">Você não tem permissão para acessar o gerenciador de administradores.</p>
                <a href="/admin" style="color: #721c24; font-weight: bold; text-decoration: underline;">Voltar para o Painel Principal</a>
            </div>
        </div>
    <% } else { %>
        
        <nav class="navbar">
            <div class="navbar-left">
                <button class="menu-toggle" id="btnMenu" title="Abrir Menu">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div class="navbar-brand">
                    <i class="fa-solid fa-store"></i>
                    <h2>Wc Variedades</h2>
                </div>
            </div>
            <div class="navbar-actions">
                <div class="theme-switcher">
                    <i class="fa-solid fa-sun"></i>
                    <label class="switch">
                        <input type="checkbox" id="themeToggle">
                        <span class="slider round"></span>
                    </label>
                    <i class="fa-solid fa-moon"></i>
                </div>
            </div>
        </nav>

        <div class="sidebar" id="sidebarMenu">
            <div id="perfilUsuario" class="badge-perfil">
                <i class="fa-solid fa-user-shield"></i> Painel Administrador
            </div>
            <hr>
            <div id="itensMenu" class="menu-links-container">
                <a href="/apresentacao" class="menu-item"><i class="fa-solid fa-house"></i> Início</a>
                <a href="/dashboard" class="menu-item"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
                <a href="/produtos" class="menu-item"><i class="fa-solid fa-boxes-stacked"></i> Gerenciar Catálogo</a>
                <a href="/admin" class="menu-item"><i class="fa-solid fa-plus"></i> Cadastrar Produto</a>
                <a href="/gerenciar-admins" class="menu-item active"><i class="fa-solid fa-users-gear"></i> Gerenciar Admins</a>
            </div>
            <hr>
            <a href="#" id="btnSair"><i class="fa-solid fa-right-from-bracket"></i> Sair / Logoff</a>
        </div>

        <div class="overlay" id="menuOverlay"></div>

        <header class="hero" style="height: 25vh;">
            <div class="hero-content">
                <h1>Gestão de Administradores</h1>
                <p>Cadastre, edite e remova privilégios administrativos secundários.</p>
            </div>
        </header>

        <main class="main-content" style="max-width: 800px; margin: 30px auto; padding: 0 20px;">
            
            <form id="formAdmin" class="form-admin">
                <h3>Cadastrar / Editar Administrador</h3>
                <div>
                    <input type="hidden" id="adminId">
                    
                    <label for="nomeAdmin" style="font-weight: 500;">Nome Completo</label>
                    <input type="text" id="nomeAdmin" placeholder="Ex: João da Silva" required>
                    
                    <label for="emailAdmin" style="font-weight: 500;">E-mail Corporativo</label>
                    <input type="email" id="emailAdmin" placeholder="exemplo@wcvariedades.com" required>
                    
                    <label for="senhaAdmin" style="font-weight: 500;">Senha de Acesso</label>
                    <input type="password" id="senhaAdmin" placeholder="Digite a senha" required>
                </div>
                <button type="submit">Cadastrar Administrador</button>
            </form>

            <h3 style="border-bottom: 2px solid var(--primary-color, #0d6efd); padding-bottom: 10px; margin-top: 40px; color: var(--text-color);">
                Lista de Administradores Secundários
            </h3>
            
            <div id="listaAdmins" style="margin-top: 20px;">
                <% 
                   const subAdmins = admins ? admins.filter(a => a.tipo_usuario !== 'admin_principal' && a.email !== 'admin@gmail.com') : [];
                %>

                <% if (subAdmins.length > 0) { %>
                    <% subAdmins.forEach(function(admin) { %>
                        <div class="card-admin-box">
                            <div>
                                <h4 style="margin: 0 0 5px 0; color: var(--text-color);">
                                    <i class="fa-solid fa-user-shield" style="color: var(--primary-color);"></i> <%= admin.nome %>
                                </h4>
                                <p style="margin: 0; font-size: 14px; color: var(--text-color-light);">
                                    <i class="fa-solid fa-envelope"></i> <%= admin.email %>
                                </p>
                            </div>
                            <div style="display: flex; gap: 8px;">
                                <button onclick="editarAdmin(<%= admin.id_usuario || admin.id_admin %>, '<%= admin.nome %>', '<%= admin.email %>')" style="background: var(--warning-color, #ffc107); color: #000; border: none; padding: 8px 15px; border-radius: 6px; cursor: pointer; font-weight: bold; display: flex; align-items: center; gap: 5px;">
                                    <i class="fa-solid fa-pen"></i> Editar
                                </button>
                                <button onclick="excluirAdmin(<%= admin.id_usuario || admin.id_admin %>)" style="background: var(--danger-color, #dc3545); color: #fff; border: none; padding: 8px 15px; border-radius: 6px; cursor: pointer; font-weight: bold; display: flex; align-items: center; gap: 5px;">
                                    <i class="fa-solid fa-trash"></i> Excluir
                                </button>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p style="font-style: italic; color: var(--text-color-light); text-align: center; padding: 20px;">
                        Nenhum administrador adicional cadastrado no momento. Use o formulário acima.
                    </p>
                <% } %>
            </div>
        </main>

        <script src="/js/gerenciar_admins.js"></script>
        <script src="/js/apresentacao.js"></script>
    <% } %> 
</body>
</html>