<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Administrativo - Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Caminho absoluto para pegar o CSS da pasta public -->
    <link rel="stylesheet" href="/css/dashboard.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="dashboard-container">
        <header class="dashboard-header">
            <div class="title-area">
                <h1><i class="fa-solid fa-chart-pie"></i> Dashboard Financeiro</h1>
                <p>Métricas e estatísticas em tempo real da loja</p>
            </div>
            <div style="display: flex; gap: 10px; align-items: center;">
                <!-- Botão de Troca de Tema -->
                <div style="display: flex; align-items: center; margin-right: 15px; font-size: 20px; cursor: pointer;">
                    <label for="themeToggle" style="cursor: pointer;" title="Mudar Tema"><i class="fa-solid fa-circle-half-stroke"></i></label>
                    <input type="checkbox" id="themeToggle" style="display:none;">
                </div>

                <a href="/produtos" class="btn-voltar"><i class="fa-solid fa-store"></i> Ver Catálogo</a>
                <button onclick="document.cookie='token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;'; localStorage.removeItem('theme'); window.location.href='/index.html';" class="btn-voltar" style="background: #dc3545;"><i class="fa-solid fa-arrow-right-from-bracket"></i> Sair</button>
            </div>
        </header>

        <!-- Controles de Filtro e Impressão -->
        <div class="controles-dashboard" style="margin-bottom: 20px; display: flex; gap: 15px; align-items: center; background: #fff; padding: 15px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
            <div>
                <label for="dataInicio" style="font-weight: bold; margin-right: 5px;">De:</label>
                <input type="date" id="dataInicio" style="padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
            
            <div>
                <label for="dataFim" style="font-weight: bold; margin-right: 5px;">Até:</label>
                <input type="date" id="dataFim" style="padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
            </div>
            
            <button onclick="filtrarPorPeriodo()" style="background: #007BFF; color: white; border: none; padding: 10px 15px; border-radius: 4px; cursor: pointer; font-weight: bold;">
                <i class="fa-solid fa-filter"></i> Filtrar
            </button>

            <button onclick="imprimirRelatorio()" style="background: #28a745; color: white; border: none; padding: 10px 15px; border-radius: 4px; cursor: pointer; font-weight: bold; margin-left: auto;">
                <i class="fa-solid fa-print"></i> Imprimir Relatório
            </button>
        </div>

        <!-- Cards de Resumo Rápido renderizados diretamente no servidor -->
        <div class="cards-grid" style="margin-top: 20px;">
            <div class="kpi-card">
                <div class="icon-box icon-blue"><i class="fa-solid fa-cart-arrow-down"></i></div>
                <div class="kpi-info">
                    <h3>Total de Pedidos</h3>
                    <!-- O EJS injeta a variável direto no HTML -->
                    <p id="totalPedidos"><%= resumo.total_pedidos %></p>
                </div>
            </div>
            <div class="kpi-card">
                <div class="icon-box icon-green"><i class="fa-solid fa-sack-dollar"></i></div>
                <div class="kpi-info">
                    <h3>Faturamento (R$)</h3>
                    <p id="receitaTotal">R$ <%= parseFloat(resumo.receita_total).toFixed(2).replace('.', ',') %></p>
                </div>
            </div>
        </div>

        <!-- Área do Gráfico -->
        <div class="chart-container">
            <h2><i class="fa-solid fa-ranking-star"></i> Top 5 Produtos Mais Vendidos</h2>
            <canvas id="graficoMaisVendidos"></canvas>
        </div>

        <!-- Tabela Relatório Detalhado (Com Loop Dinâmico do EJS) -->
        <div id="relatorioDetalhado" class="relatorio-print">
            <h2 style="margin-bottom: 15px; border-bottom: 1px solid #ccc; padding-bottom: 10px;">Relatório Detalhado de Vendas</h2>
            <table class="tabela-print">
                <thead>
                    <tr>
                        <th>ID Pedido</th>
                        <th>Cliente</th>
                        <th>Data</th>
                        <th>Valor Total</th>
                    </tr>
                </thead>
                <tbody id="tabelaRelatorioBody">
                    <% if (pedidosDetalhados && pedidosDetalhados.length > 0) { %>
                        <% pedidosDetalhados.forEach(function(pedido) { 
                            const dataFormatada = new Date(pedido.data_pedido).toLocaleDateString('pt-BR');
                            const valorFormatado = parseFloat(pedido.valor_total).toFixed(2).replace('.', ',');
                        %>
                        <tr>
                            <td>#<%= pedido.id_pedido %></td>
                            <td><%= pedido.nome_cliente || 'Cliente não identificado' %></td>
                            <td><%= dataFormatada %></td>
                            <td>R$ <%= valorFormatado %></td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="4" style="text-align:center;">Nenhum pedido encontrado.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <script src="/js/dashboard.js"></script>
    <script src="/js/apresentacao.js"></script>
</body>
</html>